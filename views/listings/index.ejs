<%layout("layouts/boilerplate")%>
<body>
   <h3>All Listings</h3>
   <!-- <form action="/listings/new" method="GET">
    <button>Create New Listing</button>
   </form> -->

   <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 ">
       <% for(let listing of allListings){ %>
         <a href="/listings/<%= listing._id %>" class="listing-link">
 <div class="card col" >
  <% const cardImage = listing.image || 'https://images.unsplash.com/photo-1773489425315-2b7664fdb068?q=80&w=687&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D'; %>
  <img src="<%= cardImage %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text"><b><%= listing.title %></b>
&#8377;<%= listing.price%>/night
</p>
  </div>
</div>
         </a>
  
<%}%>

</div>


</body>


